[gd_scene load_steps=2 format=3 uid="uid://b0mineworldlobby"]

[ext_resource type="Script" path="res://scripts/lobby.gd" id="1_lobby"]

[node name="DemoLobby" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_lobby")

[node name="Bg" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.1, 0.11, 0.14, 1)

[node name="Center" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -240.0
offset_top = -180.0
offset_right = 240.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="Center"]
layout_mode = 2
theme_override_font_sizes/font_size = 32
text = "MineWorld · Debug Menu"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="Center"]
layout_mode = 2
theme_override_colors/font_color = Color(0.7, 0.72, 0.76, 1)
text = "Default entry is 3D Hub — this page is ?menu=1 only"
horizontal_alignment = 1

[node name="BtnHub" type="Button" parent="Center"]
custom_minimum_size = Vector2(0, 48)
layout_mode = 2
text = "3D Hub (dungeon gate)"

[node name="BtnWorkshop" type="Button" parent="Center"]
custom_minimum_size = Vector2(0, 48)
layout_mode = 2
text = "Workshop (arm + gripper · IL)"

[node name="BtnCity" type="Button" parent="Center"]
custom_minimum_size = Vector2(0, 48)
layout_mode = 2
text = "City (cruise / push box)"

[node name="Hint" type="Label" parent="Center"]
layout_mode = 2
theme_override_colors/font_color = Color(0.55, 0.58, 0.62, 1)
theme_override_font_sizes/font_size = 12
text = "Esc in a level returns to Hub · see docs/18-hub-dungeon.md"
horizontal_alignment = 1
autowrap_mode = 2

[connection signal="pressed" from="BtnHub" to="." method="_on_hub_pressed"]
[connection signal="pressed" from="BtnWorkshop" to="." method="_on_workshop_pressed"]
[connection signal="pressed" from="BtnCity" to="." method="_on_city_pressed"]
