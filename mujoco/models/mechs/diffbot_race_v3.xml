<mujoco model="diffbot_race_v3">
  <!--
    Race chassis v3 (demo_race only): freejoint + contact wheels + Ackermann.
    Q/E → front steer angle; W/S → rear-wheel drive torque.
    Godot Car Kit remains viewer-only.
  -->
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"
          cone="elliptic" impratio="3"/>

  <default>
    <geom contype="1" conaffinity="1" friction="1.5 0.01 0.001"
          condim="3" solref="0.004 1" solimp="0.9 0.95 0.001"/>
    <joint damping="0.05" armature="0.02"/>
    <default class="wheel">
      <geom type="sphere" size="0.2" friction="1.5 0.01 0.001"
            condim="3" rgba="0.08 0.08 0.1 1"/>
      <joint type="hinge" axis="0 1 0" damping="0.08" armature="0.02"/>
    </default>
    <default class="susp">
      <joint type="slide" axis="0 0 1" range="-0.035 0.015"
             stiffness="12000" damping="200" armature="0.001"/>
    </default>
    <default class="steer">
      <joint type="hinge" axis="0 0 1" range="-0.55 0.55"
             damping="1.5" armature="0.01" limited="true"/>
    </default>
  </default>

  <worldbody>
    <body name="chassis" pos="0 0 0.2">
      <freejoint name="root"/>
      <inertial pos="-0.08 0 0.04" mass="32" diaginertia="0.6 1.2 1.3"/>
      <geom name="chassis_box" type="box" size="0.45 0.28 0.1" pos="0 0 0.16"
            contype="0" conaffinity="0"
            rgba="0.15 0.55 0.95 1"/>

      <!-- Front: susp → steer (yaw) → wheel roll -->
      <body name="susp_fl" pos="0.42 0.46 0">
        <inertial pos="0 0 0" mass="0.35" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_fl" class="susp"/>
        <body name="knuckle_fl" pos="0 0 0">
          <inertial pos="0 0 0" mass="0.25" diaginertia="0.001 0.001 0.001"/>
          <joint name="steer_fl" class="steer"/>
          <body name="wheel_fl" pos="0 0 0">
            <joint name="wheel_fl" class="wheel"/>
            <geom name="wheel_fl_geom" class="wheel" mass="1.1"/>
          </body>
        </body>
      </body>
      <body name="susp_fr" pos="0.42 -0.46 0">
        <inertial pos="0 0 0" mass="0.35" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_fr" class="susp"/>
        <body name="knuckle_fr" pos="0 0 0">
          <inertial pos="0 0 0" mass="0.25" diaginertia="0.001 0.001 0.001"/>
          <joint name="steer_fr" class="steer"/>
          <body name="wheel_fr" pos="0 0 0">
            <joint name="wheel_fr" class="wheel"/>
            <geom name="wheel_fr_geom" class="wheel" mass="1.1"/>
          </body>
        </body>
      </body>

      <!-- Rear: susp → driven wheel (no steer) -->
      <body name="susp_rl" pos="-0.42 0.46 0">
        <inertial pos="0 0 0" mass="0.35" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_rl" class="susp"/>
        <body name="wheel_rl" pos="0 0 0">
          <joint name="wheel_rl" class="wheel"/>
          <geom name="wheel_rl_geom" class="wheel" mass="1.2"/>
        </body>
      </body>
      <body name="susp_rr" pos="-0.42 -0.46 0">
        <inertial pos="0 0 0" mass="0.35" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_rr" class="susp"/>
        <body name="wheel_rr" pos="0 0 0">
          <joint name="wheel_rr" class="wheel"/>
          <geom name="wheel_rr_geom" class="wheel" mass="1.2"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <!-- Front steer angle (rad); Gateway maps yaw_rate [-1,1] → ctrl. -->
    <position name="steer_fl" joint="steer_fl" kp="280" kv="8"
              ctrlrange="-0.55 0.55" forcerange="-120 120"/>
    <position name="steer_fr" joint="steer_fr" kp="280" kv="8"
              ctrlrange="-0.55 0.55" forcerange="-120 120"/>
    <!-- RWD torque; Gateway maps vx [-1,1] → ctrl. -->
    <motor name="wheel_rl" joint="wheel_rl" gear="26" ctrlrange="-1 1"/>
    <motor name="wheel_rr" joint="wheel_rr" gear="26" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
