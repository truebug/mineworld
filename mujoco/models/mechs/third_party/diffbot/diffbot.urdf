<?xml version="1.0"?>
<!--
  MineWorld vendored DiffBot-style URDF (Apache-2.0).
  Geometry follows the common ros2_control DiffBot / diff_drive test layout:
  flat chassis box, left/right drive wheels, rear caster.
  Source attribution: mujoco/models/mechs/third_party/diffbot/README.md

  Simulation authority = generated MJCF (diffbot_planar.xml) with MineWorld
  planar velocity joints — not native differential wheel actuators.
-->
<robot name="diffbot">
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="12.0"/>
      <inertia ixx="0.15" ixy="0" ixz="0" iyy="0.25" iyz="0" izz="0.30"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- L x W x H (meters), Z-up -->
        <box size="0.40 0.28 0.12"/>
      </geometry>
      <material name="chassis_mat">
        <color rgba="0.20 0.55 0.90 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.28 0.12"/>
      </geometry>
    </collision>
  </link>

  <!-- Drive wheels: continuous in URDF; MJCF treats as fixed visuals -->
  <link name="wheel_left">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="wheel_mat">
        <color rgba="0.12 0.12 0.14 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="0.0 0.16 -0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="wheel_right">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <material name="wheel_mat">
        <color rgba="0.12 0.12 0.14 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0.0 -0.16 -0.04" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="caster_mat">
        <color rgba="0.35 0.35 0.38 1"/>
      </material>
    </visual>
  </link>
  <joint name="caster_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="-0.16 0 -0.055" rpy="0 0 0"/>
  </joint>

  <link name="nose">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.08 0.03"/>
      </geometry>
      <material name="nose_mat">
        <color rgba="0.95 0.75 0.15 1"/>
      </material>
    </visual>
  </link>
  <joint name="nose_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="nose"/>
    <origin xyz="0.22 0 0.02" rpy="0 0 0"/>
  </joint>
</robot>
