<mujoco model="box_mech">
  <!--
    MineWorld POC-B minimal mech (Option A).
    Planar chassis: slide x/y + hinge z, velocity actuators per joint.
    Control semantics mirror the fake integrator: ctrl = [vx, vy, yaw_rate]
    in the body frame (Z-up, forward +X). Dimensions in meters, Z-up.
  -->
  <option timestep="0.002" integrator="RK4" gravity="0 0 -9.81"/>

  <default>
    <geom contype="1" conaffinity="1" friction="0.8 0.02 0.01"/>
  </default>

  <worldbody>
    <body name="chassis" pos="0 0 0.5">
      <joint name="slide_x" type="slide" axis="1 0 0" damping="0.2"/>
      <joint name="slide_y" type="slide" axis="0 1 0" damping="0.2"/>
      <joint name="yaw_z" type="hinge" axis="0 0 1" damping="0.05"/>
      <!-- box mech: matches crate visuals (0.5m cube), CoM-centered -->
      <geom name="chassis_box" type="box" size="0.25 0.25 0.25"
            mass="10" rgba="0.62 0.42 0.22 1"/>
      <!-- heading nose (+X): visual only, no contact -->
      <geom name="nose" type="box" size="0.08 0.02 0.02" pos="0.3 0 0.1"
            mass="0" contype="0" conaffinity="0" rgba="0.85 0.2 0.15 1"/>
    </body>
  </worldbody>

  <actuator>
    <!-- velocity servos: track cmd [vx, vy, yaw_rate] directly.
         kv tuned so steady-state tracking error vs ground friction < 2%. -->
    <velocity name="vx" joint="slide_x" kv="120" forcerange="-400 400" ctrlrange="-3 3"/>
    <velocity name="vy" joint="slide_y" kv="120" forcerange="-400 400" ctrlrange="-3 3"/>
    <velocity name="yaw_rate" joint="yaw_z" kv="60" forcerange="-200 200" ctrlrange="-6 6"/>
  </actuator>
</mujoco>
