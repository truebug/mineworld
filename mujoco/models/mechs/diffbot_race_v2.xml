<mujoco model="diffbot_race_v2">
  <!--
    Race chassis v2: freejoint + 4 contact wheels (sphere contacts, motor torque).
    Climb gentle ramps / light slip / soft susp. Godot Car Kit remains viewer-only.
  -->
  <option timestep="0.002" integrator="implicitfast" gravity="0 0 -9.81"
          cone="elliptic" impratio="3"/>

  <default>
    <geom contype="1" conaffinity="1" friction="1.6 0.01 0.001"
          condim="3" solref="0.004 1" solimp="0.9 0.95 0.001"/>
    <joint damping="0.05" armature="0.02"/>
    <default class="wheel">
      <!-- Spheres contact more stably than thin cylinders at speed. -->
      <geom type="sphere" size="0.2" friction="1.45 0.01 0.001"
            condim="3" rgba="0.08 0.08 0.1 1"/>
      <joint type="hinge" axis="0 1 0" damping="0.12" armature="0.025"/>
    </default>
    <default class="susp">
      <joint type="slide" axis="0 0 1" range="-0.035 0.015"
             stiffness="12000" damping="200" armature="0.001"/>
    </default>
  </default>

  <worldbody>
    <body name="chassis" pos="0 0 0.2">
      <freejoint name="root"/>
      <inertial pos="-0.05 0 0.04" mass="30" diaginertia="0.55 1.15 1.25"/>
      <geom name="chassis_box" type="box" size="0.45 0.28 0.1" pos="0 0 0.16"
            contype="0" conaffinity="0"
            rgba="0.15 0.55 0.95 1" friction="0.4 0.01 0.01"/>

      <body name="susp_fl" pos="0.4 0.48 0">
        <inertial pos="0 0 0" mass="0.4" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_fl" class="susp"/>
        <body name="wheel_fl" pos="0 0 0">
          <joint name="wheel_fl" class="wheel"/>
          <geom name="wheel_fl_geom" class="wheel" mass="1.2"/>
        </body>
      </body>
      <body name="susp_fr" pos="0.4 -0.48 0">
        <inertial pos="0 0 0" mass="0.4" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_fr" class="susp"/>
        <body name="wheel_fr" pos="0 0 0">
          <joint name="wheel_fr" class="wheel"/>
          <geom name="wheel_fr_geom" class="wheel" mass="1.2"/>
        </body>
      </body>
      <body name="susp_rl" pos="-0.4 0.48 0">
        <inertial pos="0 0 0" mass="0.4" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_rl" class="susp"/>
        <body name="wheel_rl" pos="0 0 0">
          <joint name="wheel_rl" class="wheel"/>
          <geom name="wheel_rl_geom" class="wheel" mass="1.2"/>
        </body>
      </body>
      <body name="susp_rr" pos="-0.4 -0.48 0">
        <inertial pos="0 0 0" mass="0.4" diaginertia="0.001 0.001 0.001"/>
        <joint name="susp_rr" class="susp"/>
        <body name="wheel_rr" pos="0 0 0">
          <joint name="wheel_rr" class="wheel"/>
          <geom name="wheel_rr_geom" class="wheel" mass="1.2"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="wheel_fl" joint="wheel_fl" gear="15" ctrlrange="-1 1"/>
    <motor name="wheel_fr" joint="wheel_fr" gear="15" ctrlrange="-1 1"/>
    <motor name="wheel_rl" joint="wheel_rl" gear="24" ctrlrange="-1 1"/>
    <motor name="wheel_rr" joint="wheel_rr" gear="24" ctrlrange="-1 1"/>
  </actuator>
</mujoco>
